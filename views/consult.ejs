<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DocOnCall - Patient Portal</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=DM+Sans:wght@400;500;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            /* Professional Light Theme */
            --primary-blue: #2563EB;
            /* Trustworthy Blue */
            --primary-soft: #DBEAFE;
            /* Soft Blue Bg */
            --accent-teal: #0D9488;
            /* Healing Teal */
            --bg-body: #889fb7;
            /* Clean Light Gray */
            --bg-card: #FFFFFF;
            /* Pure White */
            --text-main: #1F2937;
            /* Dark Gray for readability */
            --text-muted: #6B7280;
            /* Soft Gray */
            --border-color: #E5E7EB;
            /* Subtle Border */
            --shadow-soft: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-hover: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -2px rgba(0, 0, 0, 0.04);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-body);
            color: var(--text-main);
            min-height: 100vh;
            padding: 20px;
        }

        .main-container {
            display: flex;
            gap: 30px;
            max-width: 1400px;
            margin: 0 auto;
            /* height: calc(100vh - 40px); */
        }

        /* Card Styles */
        .glass-panel {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            box-shadow: var(--shadow-soft);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Header */
        .section-header {
            padding: 24px 32px;
            border-bottom: 1px solid var(--border-color);
            background: #FFFFFF;
        }

        .section-header h2 {
            font-family: 'Sora', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--primary-blue);
        }

        .section-header p {
            font-size: 14px;
            color: var(--text-muted);
            margin-top: 4px;
        }

        /* Left Section: Doctors */
        .doctors-section {
            flex: 2;
            overflow-y: auto;
        }

        .patient-info-card {
            background: #F9FAFB;
            border: 1px solid var(--border-color);
            border-radius: 16px;
            margin: 24px 32px;
            padding: 24px;
        }

        .info-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--border-color);
        }

        .info-header h3 {
            color: var(--text-main);
            font-size: 18px;
            font-weight: 700;
        }

        /* Form Styles */
        .grid-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 6px;
        }

        .form-input,
        .form-select,
        .form-textarea {
            width: 100%;
            background: #FFFFFF;
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 12px;
            border-radius: 8px;
            font-family: inherit;
            font-size: 14px;
            transition: all 0.2s;
        }

        .form-input:focus,
        .form-textarea:focus {
            outline: none;
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 3px var(--primary-soft);
        }

        .submit-btn {
            width: 100%;
            background: var(--primary-blue);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }

        .submit-btn:hover {
            background: #1D4ED8;
        }

        /* Doctor List */
        .doctors-list {
            padding: 0 32px 32px;
            display: grid;
            gap: 24px;
        }

        .doctor-card {
            background: white;
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-soft);
        }

        .doctor-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary-blue);
            box-shadow: var(--shadow-hover);
        }

        .doctor-card.highlighted {
            border: 2px solid var(--accent-teal);
            background: #F0FDFA;
            /* Very light teal bg */
        }

        .ai-badge {
            background: var(--accent-teal);
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            margin-left: 10px;
            vertical-align: middle;
            letter-spacing: 0.5px;
        }

        .doc-header {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            align-items: center;
        }

        .doc-avatar {
            width: 60px;
            height: 60px;
            background: var(--primary-soft);
            color: var(--primary-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Sora', sans-serif;
            font-size: 24px;
            font-weight: 700;
        }

        .doc-info h4 {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .doc-specialty {
            display: inline-block;
            padding: 4px 12px;
            background: #EEF2FF;
            color: var(--primary-blue);
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }

        .doc-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            padding: 16px;
            background: #F9FAFB;
            border-radius: 12px;
            margin-bottom: 20px;
            border: 1px solid #F3F4F6;
        }

        .stat-item {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.5px;
        }

        .stat-val {
            color: var(--text-main);
            font-weight: 600;
            display: block;
            margin-top: 4px;
            font-size: 14px;
        }

        .book-btn {
            width: 100%;
            padding: 14px;
            background: white;
            border: 2px solid var(--primary-blue);
            border-radius: 10px;
            color: var(--primary-blue);
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

        .book-btn:hover {
            background: var(--primary-blue);
            color: white;
        }


        /* Right Section: AI Chat */
        .ai-section {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .chat-container {
            flex: 1;
            padding: 24px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
            background: #F9FAFB;
        }

        .message {
            max-width: 85%;
            padding: 14px 18px;
            border-radius: 16px;
            font-size: 14px;
            line-height: 1.6;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
        }

        .message.ai {
            align-self: flex-start;
            background: white;
            border: 1px solid var(--border-color);
            color: var(--text-main);
            border-bottom-left-radius: 4px;
        }

        .message.user {
            align-self: flex-end;
            background: var(--primary-blue);
            color: white;
            border-bottom-right-radius: 4px;
        }

        .input-area {
            padding: 24px;
            background: white;
            border-top: 1px solid var(--border-color);
        }

        .chat-input {
            width: 100%;
            background: #F9FAFB;
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 16px;
            resize: none;
            height: 90px;
        }

        .chat-input:focus {
            background: white;
            border-color: var(--primary-blue);
        }

        .suggest-btn {
            width: 100%;
            background: var(--primary-blue);
            color: white;
            padding: 14px;
            border-radius: 10px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .suggest-btn:hover {
            background: #1D4ED8;
            transform: translateY(-1px);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #D1D5DB;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #9CA3AF;
        }

        @media (max-width: 1024px) {
            .main-container {
                flex-direction: column;
                height: auto;
            }

            .doctors-section,
            .ai-section {
                width: 100%;
                height: 600px;
            }
        }

        .back-nav {
            max-width: 1400px;
            margin: 0 auto 10px;
            display: flex;
            align-items: center;
        }

        .back-link {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: color 0.2s;
            padding: 8px 12px;
            border-radius: 8px;
        }

        .back-link:hover {
            background: #E5E7EB;
            color: var(--primary-blue);
        }
    </style>
</head>

<body>

    <div class="back-nav">
        <a href="/" class="back-link">
            <span>←</span> Back to Home
        </a>
    </div>

    <div class="main-container" style="justify-content: center;">
        <!-- Central Panel: Patient Form -->
        <div class="glass-panel" style="width: 100%; max-width: 800px;">
            <div class="section-header">
                <h2>Start Consultation</h2>
                <p>Please provide your details to find the best specialists for you</p>
            </div>

            <!-- Patient Info Form -->
            <div class="patient-info-card" id="patientInfoCard"
                style="margin: 0; padding: 40px; border: none; background: white;">

                <form id="patientForm" action="/consult/book" method="POST">
                    <div class="grid-row">
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" name="name" id="patientName" class="form-input"
                                placeholder="e.g. John Doe" required>
                        </div>
                        <div class="form-group">
                            <label>Age</label>
                            <input type="number" name="age" id="patientAge" class="form-input" placeholder="e.g. 32"
                                required>
                        </div>
                    </div>
                    <div class="grid-row">
                        <div class="form-group">
                            <label>Gender</label>
                            <select name="gender" id="patientGender" class="form-select" required>
                                <option value="">Select</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input type="tel" name="contact" id="patientContact" class="form-input" placeholder="+91..."
                                required>
                        </div>
                    </div>
                    <div class="grid-row">
                        <div class="form-group">
                            <label>Preferred Date</label>
                            <input type="date" name="date" id="patientDate" class="form-input" required>
                        </div>
                        <div class="form-group">
                            <label>Preferred Time</label>
                            <input type="time" name="time" id="patientTime" class="form-input" required>
                        </div>
                    </div>
                    <div class="grid-row">
                        <div class="form-group">
                            <label>Blood Group</label>
                            <select name="bloodGroup" class="form-select" required>
                                <option value="">Select</option>
                                <option value="A+">A+</option>
                                <option value="A-">A-</option>
                                <option value="B+">B+</option>
                                <option value="B-">B-</option>
                                <option value="AB+">AB+</option>
                                <option value="AB-">AB-</option>
                                <option value="O+">O+</option>
                                <option value="O-">O-</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Chronic Conditions</label>
                            <input type="text" name="chronicConditions" class="form-input"
                                placeholder="e.g. Diabetes, None" required>
                        </div>
                    </div>
                    <div class="form-group" style="margin-bottom:15px;">
                        <label>Address (Optional)</label>
                        <textarea name="address" class="form-textarea" rows="2"
                            placeholder="Enter your address..."></textarea>
                    </div>
                    <div class="form-group" style="margin-bottom:15px;">
                        <label>Main Complaint</label>
                        <input type="text" name="problem" id="patientProblem" class="form-input"
                            placeholder="e.g. Severe Migraine" required>
                    </div>
                    <div class="form-group" style="margin-bottom:20px;">
                        <label>Detailed Symptoms</label>
                        <textarea name="symptoms" id="patientSymptoms" class="form-textarea" rows="4"
                            placeholder="Describe symptoms in detail..."></textarea>
                    </div>
                    <button type="submit" class="submit-btn">Find Doctors & Book Appointment</button>
                </form>

            </div>
        </div>
    </div>

    <script>
        // Auto-fill form from session/local storage if available
        window.onload = function () {
            const stored = localStorage.getItem('docApp_patientData');
            if (stored) {
                const data = JSON.parse(stored);
                if (document.getElementById('patientName')) document.getElementById('patientName').value = data.name || '';
                if (document.getElementById('patientAge')) document.getElementById('patientAge').value = data.age || '';
                if (document.getElementById('patientGender')) document.getElementById('patientGender').value = data.gender || '';
                if (document.getElementById('patientContact')) document.getElementById('patientContact').value = data.contact || '';
            }
        };

        // Cache data on submit for convenience
        document.getElementById('patientForm').addEventListener('submit', () => {
            const data = {
                name: document.getElementById('patientName').value,
                age: document.getElementById('patientAge').value,
                gender: document.getElementById('patientGender').value,
                contact: document.getElementById('patientContact').value
            };
            localStorage.setItem('docApp_patientData', JSON.stringify(data));
        });
    </script>
</body>

</html>