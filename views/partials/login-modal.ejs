<div id="loginModal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <span class="close-modal" onclick="closeLoginModal()">&times;</span>

        <div class="modal-body-container">
            <!-- Toggle Switch -->
            <div class="toggle-container">
                <div class="toggle-btn" id="modalToggleBtn"></div>
                <button class="toggle-option active" onclick="setModalLoginType('user')">User</button>
                <button class="toggle-option" onclick="setModalLoginType('doctor')">Doctor</button>
            </div>

            <h2 id="modalFormTitle">User Login</h2>
            <p class="subtitle" id="modalFormSubtitle">Enter your credentials to access your account</p>

            <form method="post" id="modalLoginForm" action="/login">
                <div class="form-group">
                    <label for="modalEmail">Email Address</label>
                    <input type="email" name="email" id="modalEmail" required />
                </div>

                <div class="form-group">
                    <label for="modalPassword">Password</label>
                    <input type="password" name="password" id="modalPassword" required />
                </div>

                <div class="form-options">
                    <div class="checkbox-group">
                        <input type="checkbox" id="modalRemember" />
                        <label for="modalRemember">Remember me</label>
                    </div>
                </div>

                <button type="submit" id="modalSubmitBtn">Login as User</button>
            </form>

            <div class="signup-link" id="modalSignupLinkContainer">
                Don't have an account? <a href="/signup" id="modalSignupLink">Sign up</a>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modal Styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        /* Hidden by default via inline style */
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(5px);
        animation: fadeIn 0.3s;
    }

    .modal-content {
        background: white;
        border-radius: 20px;
        padding: 40px;
        width: 100%;
        max-width: 500px;
        position: relative;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        animation: slideUp 0.4s;
    }

    .close-modal {
        position: absolute;
        top: 20px;
        right: 25px;
        font-size: 30px;
        font-weight: bold;
        color: #666;
        cursor: pointer;
        transition: color 0.3s;
    }

    .close-modal:hover {
        color: #333;
    }

    /* Reuse existing login styles or ensure they work here */
    .toggle-container {
        position: relative;
        width: 100%;
        height: 50px;
        background: #f0f0f0;
        border-radius: 25px;
        display: flex;
        margin-bottom: 30px;
        box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.1);
    }

    .toggle-btn {
        position: absolute;
        top: 2px;
        left: 0;
        width: 50%;
        height: 46px;
        background: white;
        border-radius: 23px;
        transition: all 0.3s ease;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        z-index: 1;
    }

    .toggle-option {
        flex: 1;
        border: none;
        background: transparent;
        z-index: 2;
        cursor: pointer;
        font-weight: 600;
        font-size: 16px;
        color: #666;
        transition: color 0.3s;
    }

    .toggle-option.active {
        color: #333;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 500;
    }

    .form-group input {
        width: 100%;
        padding: 12px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        outline: none;
        transition: 0.3s;
    }

    .form-group input:focus {
        border-color: #667eea;
    }

    button[type="submit"] {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        cursor: pointer;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @keyframes slideUp {
        from {
            transform: translateY(20px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
</style>

<script>
    function openLoginModal() {
        document.getElementById('loginModal').style.display = 'flex';
    }

    function closeLoginModal() {
        document.getElementById('loginModal').style.display = 'none';
    }

    // Close on click outside
    window.onclick = function (event) {
        if (event.target == document.getElementById('loginModal')) {
            closeLoginModal();
        }
    }

    function setModalLoginType(type) {
        const form = document.getElementById('modalLoginForm');
        const toggleBtn = document.getElementById('modalToggleBtn');
        const options = document.querySelectorAll('.toggle-option');
        const title = document.getElementById('modalFormTitle');
        const submitBtn = document.getElementById('modalSubmitBtn');
        const signupLink = document.getElementById('modalSignupLink');
        const signupContainer = document.getElementById('modalSignupLinkContainer');

        if (type === 'user') {
            form.action = '/login';
            toggleBtn.style.left = '0';
            options[0].classList.add('active'); // WARNING: This selects strictly by index, might affect other toggles if not scoped properly. 
            // Since this is inside the modal scope (or will be globally), we should use scoped selectors or IDs.
            // Correcting logic below to be safer.
        }

        // Actually, let's use the local scope variables
        const modalOptions = document.querySelectorAll('#loginModal .toggle-option');

        if (type === 'user') {
            form.action = '/login';
            toggleBtn.style.left = '0';
            modalOptions[0].classList.add('active');
            modalOptions[1].classList.remove('active');
            title.textContent = 'User Login';
            title.style.color = '#333';
            submitBtn.textContent = 'Login as User';
            submitBtn.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
            signupLink.href = '/signup';
            signupLink.innerText = 'Sign up';
        } else {
            form.action = '/doctor/login';
            toggleBtn.style.left = '50%';
            modalOptions[0].classList.remove('active');
            modalOptions[1].classList.add('active');
            title.textContent = 'Doctor Login';
            title.style.color = '#2c3e50';
            submitBtn.textContent = 'Login as Doctor';
            submitBtn.style.background = 'linear-gradient(135deg, #2c3e50 0%, #3498db 100%)';
            signupLink.href = '/doctor/signup';
            signupLink.innerText = 'Join as Doctor';
        }
    }
</script>